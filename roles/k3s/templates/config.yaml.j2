# /etc/rancher/k3s/config.yaml — managed by Ansible; do not edit by hand.
{% if k3s_node_role == 'server' %}
{% if k3s_tls_san %}
tls-san:
{% for san in k3s_tls_san %}
  - "{{ san }}"
{% endfor %}
{% endif %}
{% if k3s_advertise_address %}
advertise-address: "{{ k3s_advertise_address }}"
{% endif %}
{% endif %}
{% if k3s_node_ip %}
node-ip: "{{ k3s_node_ip }}"
{% endif %}
